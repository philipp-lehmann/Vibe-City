<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Tauri's webview (WKWebView) needs JIT to run JS at native speed under
         the macOS Hardened Runtime. These two are the minimal entitlements
         required for an unsandboxed Tauri app; nothing else is needed here
         since this app ships no sidecar binaries or unsigned frameworks. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
